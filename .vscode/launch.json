{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "main.ts",
      "type": "node",
      "request": "launch",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "src/main.ts"
      ],
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "cwd": "${workspaceRoot}",
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}
